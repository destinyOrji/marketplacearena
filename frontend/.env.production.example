# ========================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# Health Market Arena - Frontend
# ========================================

# API Configuration
# Point this to your backend API URL
REACT_APP_API_BASE_URL=https://api.healthmarketarena.com/api

# If backend is on same domain (e.g., via reverse proxy):
# REACT_APP_API_BASE_URL=https://healthmarketarena.com/api

# ========================================
# PAYSTACK CONFIGURATION (PRODUCTION)
# ========================================
# Get your PUBLIC key from: https://dashboard.paystack.com/#/settings/developer
# Use LIVE public key (pk_live_...) for production

REACT_APP_PAYSTACK_PUBLIC_KEY=pk_live_YOUR_PUBLIC_KEY_HERE
