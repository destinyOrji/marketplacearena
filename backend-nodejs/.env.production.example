# ========================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# Health Market Arena - Backend
# ========================================

# Server Configuration
PORT=3001
NODE_ENV=production

# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/healthmarketarena?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_very_secure_jwt_secret_change_this_in_production
JWT_EXPIRE=7d

# Email Configuration (Gmail SMTP)
# For Gmail: use an App Password (not your regular password)
# Guide: https://support.google.com/accounts/answer/185833
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=noreply@healthmarketarena.com
EMAIL_PASS=your_gmail_app_password_here

# SMS/OTP Configuration
SMS_PROVIDER=twilio

# Twilio Configuration
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890

# CORS Configuration
FRONTEND_URL=https://healthmarketarena.com

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# ========================================
# PAYSTACK CONFIGURATION (PRODUCTION)
# ========================================
# Get your keys from: https://dashboard.paystack.com/#/settings/developer
# Use LIVE keys (sk_live_... and pk_live_...) for production

PAYSTACK_SECRET_KEY=sk_live_YOUR_SECRET_KEY_HERE
PAYSTACK_PUBLIC_KEY=pk_live_YOUR_PUBLIC_KEY_HERE
